<Window x:Class="AdminTool2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AdminTool" Height="900" Width="1200"
        Background="{DynamicResource WindowBg}" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBg" Color="#F3F3F3"/>
        <SolidColorBrush x:Key="SidebarBg" Color="#EBEBEB"/>
        <SolidColorBrush x:Key="MenuBg" Color="White"/>
        <SolidColorBrush x:Key="MainText" Color="Black"/>
        <SolidColorBrush x:Key="SecText" Color="Gray"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#D2D2D2"/>
        <SolidColorBrush x:Key="InputBg" Color="White"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SidebarBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecText}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource MainText}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" 
                        Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="{TemplateBinding BorderThickness}" 
                        Padding="{TemplateBinding Padding}" 
                        SnapsToDevicePixels="True">
                            <GridViewRowPresenter Content="{TemplateBinding Content}" 
                                          Columns="{TemplateBinding GridView.ColumnCollection}" 
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#20888888"/>
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#50888888"/>
                                <Setter Property="Foreground" Value="{DynamicResource MainText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource MainText}"/>
            <Setter Property="Background" Value="{DynamicResource MenuBg}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="templateRoot" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True">
                            <Grid VerticalAlignment="Center">
                                <ContentPresenter x:Name="MenuHeader" ContentSource="Header" Margin="10,5" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" PopupAnimation="Fade" Placement="Bottom">
                                    <Border Background="{DynamicResource MenuBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="2">
                                        <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Cycle" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Right"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="templateRoot" Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TreeViewItem">
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#300078D4" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#0078D4" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#15888888" />
            </Style.Resources>
            <Setter Property="Foreground" Value="{DynamicResource MainText}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="Selection_Border" CornerRadius="4" Margin="1" Background="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <ToggleButton x:Name="Expander" Focusable="False"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Width="16" Height="16">
                                                    <Path x:Name="Arrow" Data="M 0 0 L 4 4 L 0 8 Z" 
          Fill="{DynamicResource MainText}" 
          Opacity="0.6"
          HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="0" CenterX="2" CenterY="4"/>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arrow" Property="Opacity" Value="1"/>
                                                        <Setter TargetName="Arrow" Property="RenderTransform">
                                                            <Setter.Value>
                                                                <RotateTransform Angle="90" CenterX="2" CenterY="4"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>

                                    <ContentPresenter Grid.Column="1" ContentSource="Header" Margin="5,3"/>
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Margin="18,0,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Selection_Border" Property="Background" Value="#300078D4"/>
                                <Setter Property="TextBlock.Foreground" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True" SourceName="Selection_Border">
                                <Setter TargetName="Selection_Border" Property="Background" Value="#10888888"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernSearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource MainText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#0078D4"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel x:Name="RootLayout" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled">
        <Menu DockPanel.Dock="Top" x:Name="AppMenu" Background="{DynamicResource MenuBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <MenuItem Header="Datei">
                <MenuItem Header="Beenden" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="Ansicht">
                <MenuItem Header="Design">
                    <MenuItem Header="Helles Design" Click="MenuThemeLight_Click"/>
                    <MenuItem Header="Dunkles Design" Click="MenuThemeDark_Click"/>
                </MenuItem>
                <Separator Background="{DynamicResource BorderBrush}" Height="1"/>
            </MenuItem>
            <MenuItem Header="Info">
                <MenuItem Header="Über dieses Tool" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <Grid x:Name="MainGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

<Border x:Name="SidebarBorder" Background="{DynamicResource SidebarBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="15,20,15,10">
                        <TextBlock Text="HARDWARE SUCHEN" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SecText}" Margin="5,0,0,5"/>

                        <TextBox x:Name="HardwareSearchBox" 
             Style="{StaticResource ModernSearchBox}"
             TextChanged="HardwareSearchBox_TextChanged" 
             Margin="0,0,0,15"/>


                        <TextBlock Text="HARDWARE INFO" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SecText}" Margin="5,0,0,10"/>
                        <TreeView x:Name="HardwareTree" Background="Transparent" BorderThickness="0" SelectedItemChanged="HardwareTree_SelectedItemChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <TreeViewItem x:Name="RootNode" Header="Mein System" IsExpanded="True" FontSize="15">
                                <TreeViewItem Header="💻 System &amp; Software">
                                    <TreeViewItem Header="Betriebssystem &amp; User" Tag="OS"/>
                                    <TreeViewItem Header="Laufende Prozesse" Tag="PROC"/>
                                    <TreeViewItem Header="Windows Dienste" Tag="SERV"/>
                                </TreeViewItem>
                                <TreeViewItem Header="⚙️ Mainboard &amp; CPU">
                                    <TreeViewItem Header="Mainboard &amp; BIOS" Tag="MB"/>
                                    <TreeViewItem Header="Prozessor (CPU)" Tag="CPU"/>
                                    <TreeViewItem Header="Grafikkarten (GPU)" Tag="GPU"/>
                                </TreeViewItem>
                                <TreeViewItem Header="🧠 Speicher">
                                    <TreeViewItem Header="RAM" Tag="RAM_DET"/>
                                    <TreeViewItem Header="Festplatten" Tag="DISK"/>
                                </TreeViewItem>
                                <TreeViewItem Header="🌐 Netzwerk &amp; USB">
                                    <TreeViewItem Header="Netzwerk &amp; DNS" Tag="NET"/>
                                    <TreeViewItem Header="Bluetooth Version &amp; Status" Tag="BT"/>
                                    <TreeViewItem Header="USB-Controller &amp; Geräte" Tag="USB"/>
                                </TreeViewItem>
                            </TreeViewItem>
                        </TreeView>
                    </StackPanel>
                    </DockPanel>
            </Border>

            <Grid Grid.Column="1" Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

<Grid Grid.Row="0" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />        <ColumnDefinition Width="Auto" />     <ColumnDefinition Width="Auto" />     <ColumnDefinition Width="50" />       </Grid.ColumnDefinitions>

                    <TextBlock x:Name="DetailTitle" Grid.Column="0" Text="Systemübersicht" 
                               FontSize="32" FontWeight="Bold" Foreground="{DynamicResource MainText}" 
                               VerticalAlignment="Center"/>
                    <StackPanel x:Name="SoftwareSearchPanel" Grid.Column="1" Visibility="Collapsed" 
            Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="Suchen:" VerticalAlignment="Center" FontSize="11" 
               Foreground="{DynamicResource SecText}" Margin="0,0,8,0"/>

                        <TextBox x:Name="SoftwareSearchBox" 
             Style="{StaticResource ModernSearchBox}"
             Width="180" Height="28" 
             TextChanged="SoftwareSearchBox_TextChanged"/>
                    </StackPanel>

                    <Button x:Name="BtnBulkUpdate" Grid.Column="2" Content="Auswahl aktualisieren" 
                            Click="BtnBulkUpdate_Click" Visibility="Collapsed" 
                            Padding="15,5" Background="#28A745" Foreground="White" 
                            FontSize="12" FontWeight="Bold" VerticalAlignment="Center" 
                            Margin="0,0,10,0"/>

                    <Button x:Name="HomeBtn" Grid.Column="3" Background="Transparent" BorderThickness="0" 
                            Cursor="Hand" Click="BtnHome_Click" ToolTip="Zurück zum Dashboard" 
                            VerticalAlignment="Center" HorizontalAlignment="Right" MinWidth="40">
                        <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource MainText}"/>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="DetailSubtitle" Grid.Column="0" Text="Wählen Sie eine Kategorie" 
                   FontSize="14" Foreground="{DynamicResource SecText}" VerticalAlignment="Center"/>

                </Grid>

                <Separator x:Name="MainSeparator" Grid.Row="2" VerticalAlignment="Bottom" 
                           Background="{DynamicResource BorderBrush}" Margin="0,0,0,20"/>

                <Grid Grid.Row="3">
                    <StackPanel x:Name="DashboardView" Visibility="Visible">
                        <TextBlock Text="System Live-Status" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource MainText}" Margin="0,0,0,20"/>

                        <UniformGrid Columns="2" Margin="0,0,0,20">
                            <Button x:Name="BtnDashboardUpdate" Content="Auf Updates prüfen" Click="Update_Click" 
                Margin="0,0,10,0" Height="Auto" VerticalAlignment="Stretch"
                Background="#0078D4" Foreground="White" FontWeight="Bold" Cursor="Hand">
                            </Button>

                            <Border Background="{DynamicResource MenuBg}" CornerRadius="8" Padding="10" Margin="10,0,0,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="VERFÜGBARE UPDATES" FontSize="10" Foreground="{DynamicResource SecText}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="UpdateCountText" Text="0" FontSize="38" FontWeight="Bold" Foreground="Orange" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <UniformGrid Columns="2" Margin="0,0,0,20">
                            <Border Background="{DynamicResource MenuBg}" CornerRadius="8" Padding="15" Margin="0,0,10,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="CPU Auslastung" Foreground="{DynamicResource SecText}" FontSize="12"/>
                                    <TextBlock x:Name="CpuText" Text="0%" FontSize="24" FontWeight="Bold" Foreground="#0078D4"/>
                                    <ProgressBar x:Name="CpuBar" Height="10" Minimum="0" Maximum="100" Margin="0,10,0,0" Foreground="#0078D4"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource MenuBg}" CornerRadius="8" Padding="15" Margin="10,0,0,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="RAM Verfügbar (MB)" Foreground="{DynamicResource SecText}" FontSize="12"/>
                                    <TextBlock x:Name="RamText" Text="Lade..." FontSize="24" FontWeight="Bold" Foreground="#0078D4"/>
                                    <ProgressBar x:Name="RamBar" Height="10" Minimum="0" Maximum="16384" Margin="0,10,0,0" Foreground="#28A745"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <TextBlock Text="Festplatten Belegung" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource MainText}" Margin="0,10,0,10"/>
                        <ItemsControl x:Name="DashboardDiskList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource MenuBg}" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding DriveLabel}" FontSize="20" FontWeight="Bold" Foreground="#0078D4" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                                <Grid>
                                                    <TextBlock Text="{Binding DiskModel}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource MainText}"/>
                                                    <TextBlock Text="{Binding StatusText}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{Binding BarColor}"/>
                                                </Grid>

                                                <Grid Margin="0,8,0,5">
                                                    <ProgressBar Value="{Binding PercentUsed}" Height="12" Minimum="0" Maximum="100" 
                                         Foreground="{Binding BarColor}" Background="#F0F0F0" BorderThickness="0">
                                                        <ProgressBar.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="6"/>
                                                            </Style>
                                                        </ProgressBar.Resources>
                                                    </ProgressBar>
                                                </Grid>

                                                <TextBlock Text="{Binding CapacityText}" FontSize="11" Foreground="{DynamicResource SecText}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <ScrollViewer x:Name="HardwareScroll" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <TextBlock x:Name="HardwareDetails" FontSize="16" FontFamily="Consolas" TextWrapping="Wrap" Foreground="{DynamicResource MainText}"/>
                    </ScrollViewer>

                    <ItemsControl x:Name="DiskPanel" Visibility="Collapsed">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,25">
                                    <TextBlock Text="{Binding DiskModel}" FontSize="12" FontWeight="SemiBold" Foreground="#0078D4"/>

                                    <TextBlock Text="{Binding DriveLabel}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource MainText}"/>

                                    <Grid Margin="0,5">
                                        <ProgressBar Value="{Binding PercentUsed}" Height="18" Background="#E0E0E0" Foreground="{Binding BarColor}"/>
                                        <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                    </Grid>
                                    <TextBlock Text="{Binding CapacityText}" FontSize="12" Foreground="{DynamicResource SecText}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid x:Name="SoftwareView" Visibility="Collapsed">

                        <ListView x:Name="UpdateList" Background="{DynamicResource InputBg}" Foreground="{DynamicResource MainText}" BorderBrush="{DynamicResource BorderBrush}" GridViewColumnHeader.Click="UpdateList_HeaderClick" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Auswahl" Width="60">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="280"/>
                                    <GridViewColumn Header="Version" DisplayMemberBinding="{Binding Version}" Width="100"/>
                                    <GridViewColumn Header="Neu" DisplayMemberBinding="{Binding Available}" Width="100"/>

                                    <GridViewColumn Header="Aktion" Width="120">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Update" Click="InstallRow_Click" Padding="10,3" Background="#0078D4" Foreground="White" FontSize="11" FontWeight="Bold" Cursor="Hand">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="4"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</Window> 